# ═══════════════════════════════════════════════════════════════════
# Rucher Manager — variables d'environnement
# Copiez ce fichier en « .env » et adaptez les valeurs (le script
# deploy-synology.sh le génère automatiquement avec des secrets aléatoires).
# ═══════════════════════════════════════════════════════════════════

# ─── Base de données ───────────────────────────────────────────────
# ⚠️  IMPORTANT : ce mot de passe n'est pris en compte qu'à la PREMIÈRE
# initialisation du volume PostgreSQL. Si vous le changez ensuite, vous
# obtiendrez « password authentication failed » — il faut alors réinitialiser
# le volume :  ./deploy-synology.sh --reset-db   (⚠️ efface les données).
POSTGRES_PASSWORD=change-me-strong-password

# ─── Sécurité JWT ──────────────────────────────────────────────────
# Générez une clé forte :  openssl rand -hex 32
SECRET_KEY=change-me-in-production

# ─── Premier compte administrateur (créé au 1er démarrage) ─────────
FIRST_ADMIN_EMAIL=admin@rucher.local
FIRST_ADMIN_PASSWORD=admin1234

# ─── Réseau ────────────────────────────────────────────────────────
# Port HTTP local exposé par la stack. Le proxy inverse du Synology
# (ruches.corsicajack.fr → localhost:WEB_PORT) et l'accès LAN direct
# (http://IP_DU_NAS:WEB_PORT) pointent vers ce port.
WEB_PORT=8080
